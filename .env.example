# Mainspring environment — copy to .env.local and fill in.
# Real values come from the Supabase project provisioned in Phase 6.

# Supabase project URL + anon (publishable) key.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Single-user gate: the numeric GitHub user id allowed to sign in.
# Leave unset to allow any authenticated GitHub user (e.g. local dev).
AUTHORISED_GITHUB_ID=
